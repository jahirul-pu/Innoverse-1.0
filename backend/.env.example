# Environment
NODE_ENV=development
PORT=4000

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/innoverse?schema=public"

# JWT
JWT_SECRET="change-this-to-a-random-string"
JWT_EXPIRES_IN="7d"

# OTP
OTP_EXPIRY_MINUTES=5

# CORS
CORS_ORIGIN="http://localhost:3000"

# Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=5
